@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:         #F2F5FB;
  --surface:    #FFFFFF;
  --raised:     #E8EDF8;
  --border:     #DDE3F0;
  --muted:      #9AA3BC;
  --text-dim:   #6B75A0;
  --text:       #2A3158;
  --text-hi:    #0F1730;
  --blue:       #1A3A6B;
  --blue-mid:   #2A5299;
  --blue-light: #D6E2F5;
  --green:      #1C7C54;
  --green-bg:   #D4EEE4;
  --red:        #C0392B;
  --red-bg:     #FCE8E6;
  --orange:     #B85C00;
  --orange-bg:  #FFF0DC;
  --radius:     12px;
  --shadow-sm:  0 1px 3px rgba(15,23,48,.06);
  --shadow-md:  0 4px 16px rgba(26,58,107,.14);
}

html, body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Space Grotesk', sans-serif;
  font-size: 15px;
  line-height: 1.5;
  min-height: 100dvh;
  -webkit-font-smoothing: antialiased;
}

/* ── LAYOUT ── */
.app {
  max-width: 600px;
  margin: 0 auto;
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* ── TOPBAR ── */
.topbar {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 12px 20px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
}
.topbar-brand {
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  font-weight: 700;
  color: var(--blue);
  letter-spacing: .04em;
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
}
.brand-logo {
  width: 26px; height: 26px;
  background: var(--blue);
  border-radius: 7px;
  display: grid;
  place-items: center;
  color: white;
  font-size: 13px;
}
.avatar {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: var(--blue-light);
  display: grid;
  place-items: center;
  font-size: 12px;
  font-weight: 700;
  color: var(--blue);
  cursor: pointer;
  text-decoration: none;
}

/* ── SCROLL AREA ── */
.scroll-area {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 90px;
}

/* ── BOTTOM NAV ── */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 600px;
  background: var(--surface);
  border-top: 1px solid var(--border);
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  padding: 10px 0 max(20px, env(safe-area-inset-bottom));
  z-index: 100;
}
.nav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  cursor: pointer;
  padding: 4px 0;
  text-decoration: none;
}
.nav-icon { font-size: 20px; color: var(--muted); line-height: 1; }
.nav-icon.active { color: var(--blue); }
.nav-label {
  font-size: 10px;
  color: var(--muted);
  font-weight: 500;
  font-family: 'Space Mono', monospace;
}
.nav-label.active { color: var(--blue); font-weight: 700; }
.nav-dot {
  width: 4px; height: 4px;
  border-radius: 50%;
  background: var(--blue);
  margin-top: -2px;
}

/* ── SECTIONS ── */
.section { padding: 20px 20px 0; }
.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}
.section-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted);
  font-family: 'Space Mono', monospace;
}
.section-link { font-size: 12px; color: var(--blue-mid); font-weight: 600; text-decoration: none; }

/* ── CARDS ── */
.card {
  background: var(--surface);
  border-radius: var(--radius);
  padding: 14px 16px;
  box-shadow: var(--shadow-sm);
}

/* ── BUTTONS ── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 12px 20px;
  border-radius: var(--radius);
  font-family: 'Space Grotesk', sans-serif;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  border: none;
  text-decoration: none;
  transition: opacity .15s, transform .1s;
}
.btn:active { transform: scale(.98); }
.btn-primary {
  background: var(--blue);
  color: white;
  box-shadow: var(--shadow-md);
  width: 100%;
}
.btn-primary:hover { opacity: .9; }
.btn-ghost {
  background: transparent;
  color: var(--text-dim);
  border: 1.5px solid var(--border);
}
.btn-danger { background: var(--red-bg); color: var(--red); }

/* ── FORM ── */
.form-group { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
.form-label {
  font-size: 11px;
  font-family: 'Space Mono', monospace;
  letter-spacing: .07em;
  text-transform: uppercase;
  color: var(--text-dim);
}
.form-input, .form-textarea, .form-select {
  background: var(--raised);
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: 11px 14px;
  color: var(--text-hi);
  font-family: 'Space Grotesk', sans-serif;
  font-size: 15px;
  outline: none;
  width: 100%;
  transition: border-color .15s;
  -webkit-appearance: none;
}
.form-input:focus, .form-textarea:focus, .form-select:focus {
  border-color: var(--blue);
  background: white;
}
.form-textarea { resize: vertical; min-height: 80px; }
.form-error { font-size: 12px; color: var(--red); margin-top: 4px; }

/* ── TYPE SELECTOR ── */
.type-selector { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
.type-btn {
  padding: 10px 6px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  background: var(--raised);
  color: var(--text-dim);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  text-align: center;
  transition: all .15s;
}
.type-btn.active-training { border-color: var(--blue); color: var(--blue); background: var(--blue-light); }
.type-btn.active-seminar  { border-color: var(--orange); color: var(--orange); background: var(--orange-bg); }
.type-btn.active-comp     { border-color: var(--red); color: var(--red); background: var(--red-bg); }

/* ── ENTRY CARDS ── */
.entry-card {
  background: var(--surface);
  border-radius: var(--radius);
  padding: 14px 16px;
  box-shadow: var(--shadow-sm);
  display: flex;
  gap: 12px;
  align-items: flex-start;
  text-decoration: none;
  color: inherit;
  transition: transform .1s;
}
.entry-card:active { transform: scale(.99); }
.entry-dot { width: 9px; height: 9px; border-radius: 50%; margin-top: 5px; flex-shrink: 0; }
.dot-training { background: var(--blue-mid); }
.dot-seminar  { background: var(--orange); }
.dot-competitie { background: var(--red); }
.entry-body { flex: 1; min-width: 0; }
.entry-title { font-size: 14px; font-weight: 600; color: var(--text-hi); margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.entry-meta { font-size: 12px; color: var(--muted); display: flex; gap: 10px; margin-bottom: 7px; }
.entry-dur { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--muted); flex-shrink: 0; margin-top: 3px; }

/* ── TAGS ── */
.tags { display: flex; gap: 5px; flex-wrap: wrap; }
.tag { font-size: 11px; padding: 2px 7px; border-radius: 5px; font-family: 'Space Mono', monospace; }
.tag-blue   { background: var(--blue-light); color: var(--blue); }
.tag-orange { background: var(--orange-bg);  color: var(--orange); }
.tag-green  { background: var(--green-bg);   color: var(--green); }
.tag-red    { background: var(--red-bg);     color: var(--red); }

/* ── GOAL ITEMS ── */
.goal-item { background: var(--surface); border-radius: var(--radius); padding: 13px 16px; display: flex; align-items: center; gap: 11px; box-shadow: var(--shadow-sm); }
.goal-check { width: 22px; height: 22px; border-radius: 6px; border: 2px solid var(--border); flex-shrink: 0; display: grid; place-items: center; font-size: 11px; cursor: pointer; }
.goal-check.done { background: var(--green); border-color: var(--green); color: white; }
.goal-check.bezig { border-color: var(--blue-mid); }
.goal-text { font-size: 14px; color: var(--text); flex: 1; font-weight: 500; }
.goal-text.done { text-decoration: line-through; color: var(--muted); font-weight: 400; }

/* ── BELT CARD ── */
.belt-card {
  margin: 14px 20px 0;
  background: var(--blue);
  border-radius: 16px;
  padding: 18px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
}
.belt-card::before {
  content: '';
  position: absolute; right: -20px; top: -30px;
  width: 120px; height: 120px;
  border-radius: 50%;
  background: rgba(255,255,255,.07);
  pointer-events: none;
}
.belt-label { font-size: 11px; color: rgba(255,255,255,.55); font-family: 'Space Mono', monospace; letter-spacing: .08em; text-transform: uppercase; margin-bottom: 2px; }
.belt-name  { font-size: 18px; font-weight: 700; color: white; }
.belt-stripes { display: flex; gap: 4px; margin-top: 8px; }
.stripe { width: 18px; height: 5px; border-radius: 2px; background: rgba(255,255,255,.2); }
.stripe.filled { background: white; }
.belt-stat { text-align: right; position: relative; z-index: 1; }
.belt-stat-val   { font-size: 28px; font-weight: 700; color: white; line-height: 1; }
.belt-stat-label { font-size: 11px; color: rgba(255,255,255,.55); font-family: 'Space Mono', monospace; }

/* ── STATS ROW ── */
.stats-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 14px 20px 0; }
.stat-card { background: var(--surface); border-radius: var(--radius); padding: 14px 16px; box-shadow: var(--shadow-sm); }
.stat-label { font-size: 10px; font-family: 'Space Mono', monospace; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin-bottom: 5px; }
.stat-value { font-size: 28px; font-weight: 700; color: var(--text-hi); line-height: 1; }
.stat-sub   { font-size: 11px; color: var(--muted); margin-top: 3px; }
.c-green { color: var(--green); }
.c-blue  { color: var(--blue); }

/* ── LOG BTN ── */
.log-btn {
  margin: 16px 20px 0;
  background: var(--blue);
  color: white;
  border: none;
  border-radius: 14px;
  padding: 16px 20px;
  font-family: 'Space Grotesk', sans-serif;
  font-size: 15px;
  font-weight: 700;
  width: calc(100% - 40px);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(26,58,107,.28);
  text-decoration: none;
  transition: opacity .15s;
}
.log-btn:active { opacity: .9; }
.log-btn-icon { width: 26px; height: 26px; background: rgba(255,255,255,.2); border-radius: 7px; display: grid; place-items: center; font-size: 14px; }

/* ── AUTH PAGES ── */
.auth-page { min-height: 100dvh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 32px 24px; }
.auth-card { background: var(--surface); border-radius: 20px; padding: 28px 24px; width: 100%; max-width: 400px; box-shadow: 0 8px 40px rgba(15,23,48,.12); }
.auth-logo { text-align: center; margin-bottom: 24px; }
.auth-title { font-size: 20px; font-weight: 700; color: var(--text-hi); margin-bottom: 4px; text-align: center; }
.auth-sub   { font-size: 13px; color: var(--muted); text-align: center; margin-bottom: 24px; }
.auth-link  { text-align: center; margin-top: 16px; font-size: 13px; color: var(--text-dim); }
.auth-link a { color: var(--blue); font-weight: 600; text-decoration: none; }

/* ── EMPTY STATE ── */
.empty { text-align: center; padding: 40px 20px; }
.empty-icon { font-size: 40px; margin-bottom: 12px; }
.empty-title { font-size: 16px; font-weight: 600; color: var(--text-hi); margin-bottom: 6px; }
.empty-sub   { font-size: 13px; color: var(--muted); }
