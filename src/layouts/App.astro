---
import '../styles/global.css';
import { createAuth } from '../lib/auth';

const { title = 'BJJ Dagboek', page = '' } = Astro.props;

// Haal sessie op
let user = null;
try {
  const runtime = Astro.locals.runtime;
  if (runtime?.env?.DB) {
    const auth = createAuth(runtime.env.DB);
    const session = await auth.api.getSession({ headers: Astro.request.headers });
    user = session?.user ?? null;
  }
} catch (e) {}

const initials = user?.name
  ? user.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase()
  : '?';
---
<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <meta name="theme-color" content="#1A3A6B" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <title>{title} — BJJ Dagboek</title>
</head>
<body>
<div class="app">
  <header class="topbar">
    <a href="/dashboard" class="topbar-brand">
      <div class="brand-logo">⬡</div>
      BJJ Dagboek
    </a>
    {user && <a href="/profiel" class="avatar">{initials}</a>}
  </header>

  <main class="scroll-area">
    <slot />
  </main>

  {user && (
    <nav class="bottom-nav">
      <a href="/dashboard" class="nav-btn">
        <div class={`nav-icon ${page === 'home' ? 'active' : ''}`}>⌂</div>
        <div class={`nav-label ${page === 'home' ? 'active' : ''}`}>Home</div>
        {page === 'home' && <div class="nav-dot"></div>}
      </a>
      <a href="/logboek" class="nav-btn">
        <div class={`nav-icon ${page === 'logboek' ? 'active' : ''}`}>✦</div>
        <div class={`nav-label ${page === 'logboek' ? 'active' : ''}`}>Logboek</div>
        {page === 'logboek' && <div class="nav-dot"></div>}
      </a>
      <a href="/loggen" class="nav-btn">
        <div class={`nav-icon ${page === 'loggen' ? 'active' : ''}`}>＋</div>
        <div class={`nav-label ${page === 'loggen' ? 'active' : ''}`}>Loggen</div>
        {page === 'loggen' && <div class="nav-dot"></div>}
      </a>
      <a href="/doelen" class="nav-btn">
        <div class={`nav-icon ${page === 'doelen' ? 'active' : ''}`}>⊕</div>
        <div class={`nav-label ${page === 'doelen' ? 'active' : ''}`}>Doelen</div>
        {page === 'doelen' && <div class="nav-dot"></div>}
      </a>
      <a href="/voortgang" class="nav-btn">
        <div class={`nav-icon ${page === 'voortgang' ? 'active' : ''}`}>◎</div>
        <div class={`nav-label ${page === 'voortgang' ? 'active' : ''}`}>Groei</div>
        {page === 'voortgang' && <div class="nav-dot"></div>}
      </a>
    </nav>
  )}
</div>
</body>
</html>
